# --- strkd wallet companion (loopback; holds keys, signs, bundles the prover) ---
STRKD_URL=http://127.0.0.1:PORT        # discover the port from the companion (GET /)
STRKD_TOKEN=                            # from companion_requestPairing; persists across restarts

# --- Your funded + deployed agent account (created via strkd) ---
ACCOUNT_ADDRESS=0x...

# --- Public read RPC (status / nonce / class-hash; carries no secrets). v0.8+ ---
READ_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia

# --- Confidential state (NEVER published; NEVER fee-estimated online) ---
SALT=0x...                              # blinding factor for the shard state commitment (secret)
DEPLOY_SALT=0x1234abcd                  # UDC deploy salt (public)
