# --- Starknet (server-side ONLY: private inputs + signing keys must never reach a browser) ---
RPC_URL=https://rpc.starknet-testnet.lava.build   # v0.8+ JSON-RPC
ACCOUNT_ADDRESS=0x...
PRIVATE_KEY=0x...
CONTRACT_ADDRESS=0x...                             # deployed ConfidentialCounter

# --- Proof server (Rust snip36 backend wrapped in the SSE /prove endpoint) ---
PROOF_SERVER_URL=http://localhost:3030

# --- Off-chain confidential state (NEVER published; NEVER fee-estimated online) ---
# The whole point of the design: this is the secret pre-state the proof runs over.
STATE_COUNT=0
STATE_SALT=0x...                                   # blinding factor; keep secret & durable
STEP=1                                             # public action param
